generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum BookingStatus {
  pending
  confirmed
  in_progress
  completed
  cancelled

  @@map("booking_status")
}

enum InvoiceStatus {
  draft
  sent
  paid
  overdue
  cancelled

  @@map("invoice_status")
}

enum SubscriptionStatus {
  active
  cancelled
  paused

  @@map("subscription_status")
}

enum SubscriptionPlan {
  essential
  pro
  elite

  @@map("subscription_plan")
}

enum PaymentCheckoutStatus {
  pending
  paid
  failed
  cancelled

  @@map("payment_checkout_status")
}

enum PaymentCheckoutKind {
  membership
  invoice

  @@map("payment_checkout_kind")
}

enum NotificationType {
  info
  success
  warning
  error
  booking
  invoice
  message
  review

  @@map("notification_type")
}

enum TodoPriority {
  low
  medium
  high

  @@map("todo_priority")
}

enum UserRole {
  customer
  tech

  @@map("user_role")
}

model User {
  id                       String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                    String?           @unique
  passwordHash             String?           @map("password_hash")
  name                     String
  phone                    String?
  avatarUrl                String?           @map("avatar_url")
  role                     UserRole          @default(customer)
  googleId                 String?           @unique @map("google_id")
  emailVerified            Boolean?          @default(false) @map("email_verified")
  passwordResetToken       String?           @map("password_reset_token")
  passwordResetExpires     DateTime?         @map("password_reset_expires") @db.Timestamptz(6)
  emailVerificationToken   String?           @map("email_verification_token")
  emailVerificationExpires DateTime?         @map("email_verification_expires") @db.Timestamptz(6)
  pendingEmail             String?           @map("pending_email")
  lastSeenAt               DateTime?         @map("last_seen_at") @db.Timestamptz(6)
  createdAt                DateTime?         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime?         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  bookingsAsCustomer       Booking[]         @relation("CustomerBookings")
  bookingsAsTech           Booking[]         @relation("TechBookings")
  convosAsCustomer         Conversation[]    @relation("CustomerConversations")
  convosAsTech             Conversation[]    @relation("TechConversations")
  homes                    Home[]
  invoices                 Invoice[]
  sentMessages             Message[]
  notifications            Notification[]
  reviewsGiven             Review[]          @relation("CustomerReviews")
  reviewsReceived          Review[]          @relation("TechReviews")
  serviceAreas             ServiceArea[]
  subscriptions            Subscription[]
  bookingNotes             BookingNote[]     @relation("AuthoredBookingNotes")
  notifyPrefs              Json?             @map("notify_prefs")
  appointmentReminders     Json?             @map("appointment_reminders")
  createdHomeInvitations   HomeInvitation[]  @relation("CreatedHomeInvitations")
  paymentCheckouts         PaymentCheckout[]

  @@index([passwordResetToken], map: "idx_users_password_reset_token")
  @@index([emailVerificationToken], map: "idx_users_email_verification_token")
  @@index([role], map: "idx_users_role")
  @@index([lastSeenAt], map: "idx_users_last_seen_at")
  @@map("users")
}

model Home {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId       String            @map("customer_id") @db.Uuid
  address          String
  city             String?
  state            String?           @default("TX")
  zip              String?
  lat              Float?
  lng              Float?
  notes            String?
  gateCode         String?           @map("gate_code")
  wifiName         String?           @map("wifi_name")
  wifiPassword     String?           @map("wifi_password")
  yearBuilt        Int?              @map("year_built")
  waterHeaterYear  Int?              @map("water_heater_year")
  panelAmps        Int?              @map("panel_amps")
  createdAt        DateTime?         @default(now()) @map("created_at") @db.Timestamptz(6)
  bookings         Booking[]
  customer         User              @relation(fields: [customerId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  photos           Photo[]
  householdMembers HouseholdMember[]
  todos            HomeTodo[]
  techNotes        HomeNote[]
  appliances       HomeAppliance[]
  subscriptions    Subscription[]
  invitations      HomeInvitation[]
  paymentCheckouts PaymentCheckout[]

  @@index([customerId], map: "idx_homes_customer")
  @@map("homes")
}

model HomeAppliance {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  homeId         String    @map("home_id") @db.Uuid
  name           String
  brand          String?
  modelNumber    String?   @map("model_number")
  installedAt    DateTime? @map("installed_at") @db.Timestamptz(6)
  intervalDays   Int?      @map("interval_days")
  lastServicedAt DateTime? @map("last_serviced_at") @db.Timestamptz(6)
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  home           Home      @relation(fields: [homeId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([homeId], map: "idx_home_appliances_home")
  @@map("home_appliances")
}

model HouseholdMember {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  homeId    String    @map("home_id") @db.Uuid
  name      String
  role      String?
  phone     String?
  sortOrder Int?      @default(0) @map("sort_order")
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  home      Home      @relation(fields: [homeId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([homeId], map: "idx_household_members_home")
  @@map("household_members")
}

model HomeTodo {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  homeId           String       @map("home_id") @db.Uuid
  task             String
  description      String?
  priority         TodoPriority @default(medium)
  status           String       @default("pending")
  parts            String?
  partStatus       String?      @map("part_status")
  partsDescription String?      @map("parts_description")
  partsBuyer       String?      @map("parts_buyer")
  specialist       Boolean?     @default(false)
  hasPhoto         Boolean?     @default(false) @map("has_photo")
  photoIds         String[]     @default([]) @map("photo_ids") @db.Uuid
  notes            String?
  sortOrder        Int?         @default(0) @map("sort_order")
  createdAt        DateTime?    @default(now()) @map("created_at") @db.Timestamptz(6)
  home             Home         @relation(fields: [homeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  bookingTasks     Task[]

  @@index([homeId], map: "idx_home_todos_home")
  @@map("home_todos")
}

model HomeNote {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  homeId     String    @map("home_id") @db.Uuid
  title      String
  body       String?
  severity   String?   @default("info")
  authorId   String?   @map("author_id") @db.Uuid
  authorName String?   @map("author_name")
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  home       Home      @relation(fields: [homeId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([homeId], map: "idx_home_notes_home")
  @@map("home_notes")
}

model ServiceCategory {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String            @unique
  icon      String?
  sortOrder Int?              @default(0) @map("sort_order")
  bookings  BookingCategory[]

  @@map("service_categories")
}

model Booking {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId      String            @map("customer_id") @db.Uuid
  homeId          String?           @map("home_id") @db.Uuid
  techId          String?           @map("tech_id") @db.Uuid
  status          BookingStatus     @default(pending)
  scheduledDate   DateTime          @map("scheduled_date") @db.Date
  scheduledTime   DateTime          @map("scheduled_time") @db.Time(6)
  durationMinutes Int?              @default(120) @map("duration_minutes")
  serviceType     String?           @default("one_time") @map("service_type")
  description     String?
  customerNotes   String?           @map("customer_notes")
  techNotes       String?           @map("tech_notes")
  estimatedCost   Decimal?          @map("estimated_cost") @db.Decimal(10, 2)
  finalCost       Decimal?          @map("final_cost") @db.Decimal(10, 2)
  createdAt       DateTime?         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime?         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  categories      BookingCategory[]
  customer        User              @relation("CustomerBookings", fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  home            Home?             @relation(fields: [homeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tech            User?             @relation("TechBookings", fields: [techId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  invoices        Invoice[]
  parts           Part[]
  photos          Photo[]
  reviews         Review[]
  tasks           Task[]
  bookingNotes    BookingNote[]

  @@index([customerId], map: "idx_bookings_customer")
  @@index([techId], map: "idx_bookings_tech")
  @@index([scheduledDate], map: "idx_bookings_date")
  @@index([status], map: "idx_bookings_status")
  @@map("bookings")
}

model BookingCategory {
  bookingId  String          @map("booking_id") @db.Uuid
  categoryId String          @map("category_id") @db.Uuid
  booking    Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  category   ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([bookingId, categoryId])
  @@map("booking_categories")
}

model Task {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId  String    @map("booking_id") @db.Uuid
  homeTodoId String?   @map("home_todo_id") @db.Uuid
  label      String
  done       Boolean?  @default(false)
  notes      String?
  sortOrder  Int?      @default(0) @map("sort_order")
  booking    Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  homeTodo   HomeTodo? @relation(fields: [homeTodoId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([homeTodoId], map: "idx_tasks_home_todo")
  @@map("tasks")
}

model Part {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId String   @map("booking_id") @db.Uuid
  item      String
  qty       Int?     @default(1)
  cost      Decimal? @db.Decimal(10, 2)
  status    String?  @default("needed")
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("parts")
}

model Photo {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId  String?   @map("booking_id") @db.Uuid
  homeId     String?   @map("home_id") @db.Uuid
  url        String
  label      String?
  type       String?   @default("before")
  uploadedAt DateTime? @default(now()) @map("uploaded_at") @db.Timestamptz(6)
  booking    Booking?  @relation(fields: [bookingId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  home       Home?     @relation(fields: [homeId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([bookingId], map: "idx_photos_booking")
  @@index([homeId], map: "idx_photos_home")
  @@map("photos")
}

model Conversation {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId    String    @map("customer_id") @db.Uuid
  techId        String    @map("tech_id") @db.Uuid
  lastMessageAt DateTime? @default(now()) @map("last_message_at") @db.Timestamptz(6)
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  customer      User      @relation("CustomerConversations", fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tech          User      @relation("TechConversations", fields: [techId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  messages      Message[]

  @@index([customerId], map: "idx_conversations_customer")
  @@index([techId], map: "idx_conversations_tech")
  @@map("conversations")
}

model Message {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String       @map("conversation_id") @db.Uuid
  senderId       String       @map("sender_id") @db.Uuid
  text           String
  type           String?      @default("text")
  read           Boolean?     @default(false)
  createdAt      DateTime?    @default(now()) @map("created_at") @db.Timestamptz(6)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([conversationId, createdAt], map: "idx_messages_convo")
  @@map("messages")
}

model Review {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId  String    @map("booking_id") @db.Uuid
  customerId String    @map("customer_id") @db.Uuid
  techId     String    @map("tech_id") @db.Uuid
  rating     Int
  comment    String?
  categories String[]
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  booking    Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  customer   User      @relation("CustomerReviews", fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tech       User      @relation("TechReviews", fields: [techId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([techId], map: "idx_reviews_tech")
  @@index([bookingId], map: "idx_reviews_booking")
  @@map("reviews")
}

model Invoice {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId        String            @map("booking_id") @db.Uuid
  customerId       String            @map("customer_id") @db.Uuid
  number           String            @unique
  subtotal         Decimal           @db.Decimal(10, 2)
  tax              Decimal?          @default(0) @db.Decimal(10, 2)
  total            Decimal           @db.Decimal(10, 2)
  status           InvoiceStatus     @default(draft)
  sentAt           DateTime?         @map("sent_at") @db.Timestamptz(6)
  paidAt           DateTime?         @map("paid_at") @db.Timestamptz(6)
  createdAt        DateTime?         @default(now()) @map("created_at") @db.Timestamptz(6)
  booking          Booking           @relation(fields: [bookingId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customer         User              @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  paymentCheckouts PaymentCheckout[]

  @@index([customerId], map: "idx_invoices_customer")
  @@index([bookingId], map: "idx_invoices_booking")
  @@map("invoices")
}

model ServiceArea {
  id     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  techId String   @map("tech_id") @db.Uuid
  city   String
  active Boolean? @default(true)
  lat    Float?
  lng    Float?
  tech   User     @relation(fields: [techId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([techId, city])
  @@map("service_areas")
}

model Notification {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  title     String
  body      String?
  type      NotificationType @default(info)
  read      Boolean?         @default(false)
  link      String?
  createdAt DateTime?        @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId, createdAt], map: "idx_notifications_user_created")
  @@map("notifications")
}

model Subscription {
  id         String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId String              @map("customer_id") @db.Uuid
  homeId     String?             @map("home_id") @db.Uuid
  plan       SubscriptionPlan    @default(essential)
  status     SubscriptionStatus? @default(active)
  visitsUsed Int                 @default(0) @map("visits_used")
  startedAt  DateTime?           @default(now()) @map("started_at") @db.Timestamptz(6)
  endsAt     DateTime?           @map("ends_at") @db.Timestamptz(6)
  customer   User                @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  home       Home?               @relation(fields: [homeId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([homeId, status], map: "idx_subscriptions_home_status")
  @@index([customerId, status], map: "idx_subscriptions_customer_status")
  @@map("subscriptions")
}

model HomeInvitation {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  homeId      String    @map("home_id") @db.Uuid
  email       String
  tokenHash   String    @unique @map("token_hash")
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz(6)
  acceptedAt  DateTime? @map("accepted_at") @db.Timestamptz(6)
  createdById String    @map("created_by_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  home        Home      @relation(fields: [homeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  createdBy   User      @relation("CreatedHomeInvitations", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([homeId, acceptedAt, expiresAt], map: "idx_home_invitations_home_status")
  @@index([email, acceptedAt], map: "idx_home_invitations_email_status")
  @@map("home_invitations")
}

model PaymentCheckout {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId          String                @map("customer_id") @db.Uuid
  homeId              String?               @map("home_id") @db.Uuid
  invoiceId           String?               @map("invoice_id") @db.Uuid
  kind                PaymentCheckoutKind   @default(membership)
  plan                SubscriptionPlan?
  amountCents         Int                   @map("amount_cents")
  currency            String                @default("USD")
  status              PaymentCheckoutStatus @default(pending)
  idempotencyKey      String                @unique @map("idempotency_key")
  squarePaymentLinkId String?               @unique @map("square_payment_link_id")
  squareOrderId       String?               @unique @map("square_order_id")
  squarePaymentId     String?               @unique @map("square_payment_id")
  paidAt              DateTime?             @map("paid_at") @db.Timestamptz(6)
  createdAt           DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  customer            User                  @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  home                Home?                 @relation(fields: [homeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  invoice             Invoice?              @relation(fields: [invoiceId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([customerId, createdAt], map: "idx_payment_checkouts_customer_created")
  @@index([homeId, status], map: "idx_payment_checkouts_home_status")
  @@index([invoiceId, status], map: "idx_payment_checkouts_invoice_status")
  @@map("payment_checkouts")
}

model SquareWebhookEvent {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId     String   @unique @map("event_id")
  type        String
  payloadHash String   @map("payload_hash")
  processedAt DateTime @default(now()) @map("processed_at") @db.Timestamptz(6)

  @@map("square_webhook_events")
}

model BusinessProfile {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  techId               String   @unique @map("tech_id") @db.Uuid
  businessName         String?  @map("business_name")
  licenseNumber        String?  @map("license_number")
  workingHours         Json?    @map("working_hours")
  notifyPrefs          Json?    @map("notify_prefs")
  bio                  String?
  phone                String?
  venmoHandle          String?  @map("venmo_handle")
  zelleHandle          String?  @map("zelle_handle")
  cashappHandle        String?  @map("cashapp_handle")
  paypalEmail          String?  @map("paypal_email")
  appointmentReminders Json?    @map("appointment_reminders")
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("business_profiles")
}

model AvailabilityBlock {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  techId    String   @map("tech_id") @db.Uuid
  startAt   DateTime @map("start_at") @db.Timestamptz(6)
  endAt     DateTime @map("end_at") @db.Timestamptz(6)
  reason    String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([techId, startAt], map: "idx_availability_tech")
  @@map("availability_blocks")
}

model BookingNote {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId String   @map("booking_id") @db.Uuid
  authorId  String   @map("author_id") @db.Uuid
  text      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  author  User    @relation("AuthoredBookingNotes", fields: [authorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([bookingId], map: "idx_booking_notes_booking")
  @@map("booking_notes")
}
